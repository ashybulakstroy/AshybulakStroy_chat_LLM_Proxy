PORT=8800
ENABLE_PROVIDER_LOG=true
LOG_LEVEL=INFO
ALLOW_RUNTIME_ADMIN_MUTATIONS=false

OPENAI_API_KEY=your-openai-api-key
OPENAI_API_BASE=https://api.openai.com/v1

GROQ_API_KEY=your-groq-api-key
GROQ_API_BASE=https://api.groq.com/openai/v1

OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_API_BASE=https://openrouter.ai/api/v1

CEREBRAS_API_KEY=your-cerebras-api-key
CEREBRAS_API_BASE=https://api.cerebras.ai/v1

GEMINI_API_KEY=your-gemini-api-key
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai/

SAMBANOVA_API_KEY=your-sambanova-api-key
SAMBANOVA_API_BASE=https://api.sambanova.ai/v1

EDENAI_API_KEY=your-edenai-api-key
EDENAI_API_BASE=https://api.edenai.run/v3/llm

FIREWORKS_API_KEY=your-fireworks-api-key
FIREWORKS_API_BASE=https://api.fireworks.ai/inference/v1

# P2P core
P2P_ENABLED=false
NODE_MODE=peer
P2P_SCOPE=private
P2P_NODE_NAME=home-node
P2P_NODE_ID=
P2P_CLUSTER_NAME=default
P2P_BASE_URL=
P2P_MASTER_URL=
P2P_ALLOW_MASTER=true

# P2P participation
P2P_ACCEPT_REMOTE_TASKS=true
P2P_SHARE_CAPACITY=true
P2P_SHARED_RPM_RATIO=1.0
P2P_SHARED_TPM_RATIO=1.0
P2P_MAX_CLIENT_SLOTS_PER_MIN=1
P2P_MAX_SHARED_SLOTS_PER_MIN=5

# P2P session limits
P2P_MAX_REMOTE_SESSIONS=3
P2P_MAX_OUTGOING_SESSIONS=5
P2P_MAX_QUEUE_SIZE=50
P2P_SESSION_TIMEOUT_SEC=90
P2P_PER_PEER_RPM_LIMIT=20
P2P_PER_TARGET_PEER_RPM_LIMIT=20
P2P_GLOBAL_INCOMING_RPM_LIMIT=60
P2P_GLOBAL_OUTGOING_RPM_LIMIT=60
P2P_HEARTBEAT_INTERVAL_SEC=15
P2P_PEER_STALE_AFTER_SEC=45
P2P_ROUTE_TTL_MIN=1440
